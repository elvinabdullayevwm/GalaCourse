<!DOCTYPE html>
<html lang="az">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GALA COURSE</title>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Montserrat',sans-serif;
}

body{
background:#000;
color:#fff;
overflow-x:hidden;
}

:root{
--gold:#d4af37;
--dark:#0b0b0b;
}

header{
position:fixed;
top:0;
width:100%;
padding:20px 8%;
display:flex;
justify-content:space-between;
align-items:center;
background:rgba(0,0,0,.85);
backdrop-filter:blur(10px);
z-index:1000;
border-bottom:1px solid rgba(212,175,55,.2);
}

.logo{
color:var(--gold);
font-size:28px;
font-weight:800;
letter-spacing:2px;
}

nav a{
text-decoration:none;
color:white;
margin-left:30px;
font-weight:500;
transition:.3s;
}

nav a:hover{
color:var(--gold);
}

.hero{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
background:
linear-gradient(rgba(0,0,0,.75),rgba(0,0,0,.85)),
url('https://images.unsplash.com/photo-1519452575417-564c1401ecc0?q=80&w=1920');
background-size:cover;
background-position:center;
}

.hero-content{
max-width:900px;
}

.hero h1{
font-size:75px;
color:var(--gold);
font-weight:800;
margin-bottom:20px;
}

.hero p{
font-size:22px;
line-height:1.8;
color:#ddd;
margin-bottom:35px;
}

.btn{
display:inline-block;
padding:15px 40px;
background:var(--gold);
color:black;
font-weight:700;
text-decoration:none;
border-radius:50px;
transition:.3s;
}

.btn:hover{
transform:translateY(-3px);
box-shadow:0 0 25px rgba(212,175,55,.5);
}

section{
padding:100px 8%;
}

.section-title{
text-align:center;
font-size:42px;
color:var(--gold);
margin-bottom:60px;
}

.about{
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
align-items:center;
}

.about-text h3{
font-size:32px;
color:var(--gold);
margin-bottom:20px;
}

.about-text p{
line-height:1.9;
color:#ccc;
}

.about-box{
height:350px;
border:2px solid rgba(212,175,55,.4);
border-radius:20px;
display:flex;
justify-content:center;
align-items:center;
font-size:90px;
color:var(--gold);
}

.courses{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:#111;
padding:35px;
border-radius:15px;
border:1px solid rgba(212,175,55,.15);
transition:.4s;
}

.card:hover{
transform:translateY(-8px);
border-color:var(--gold);
}

.card h3{
color:var(--gold);
margin-bottom:15px;
}

.card p{
color:#aaa;
line-height:1.8;
}

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:30px;
text-align:center;
}

.stat{
padding:40px;
border:1px solid rgba(212,175,55,.2);
border-radius:15px;
}

.stat h2{
font-size:55px;
color:var(--gold);
margin-bottom:10px;
}

.contact{
text-align:center;
}

.contact-box{
max-width:700px;
margin:auto;
padding:50px;
border:1px solid rgba(212,175,55,.25);
border-radius:20px;
background:#0c0c0c;
}

.contact-box h3{
color:var(--gold);
font-size:28px;
margin-bottom:20px;
}

.contact-box p{
margin-bottom:15px;
font-size:18px;
}

footer{
padding:40px;
text-align:center;
border-top:1px solid rgba(212,175,55,.2);
color:#aaa;
}

@media(max-width:768px){

.hero h1{
font-size:50px;
}

.about{
grid-template-columns:1fr;
}

nav{
display:none;
}

}

</style>
</head>
